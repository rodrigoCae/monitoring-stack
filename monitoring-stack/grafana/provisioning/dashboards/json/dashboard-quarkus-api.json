{
  "title": "Gateway de Pagamentos - API Quarkus",
  "uid": "quarkus-api-detail",
  "timezone": "browser",
  "schemaVersion": 39,
  "version": 1,
  "refresh": "5s",
  "time": { "from": "now-15m", "to": "now" },
  "panels": [
    { "type": "row", "title": "HTTP", "gridPos": { "h": 1, "w": 24, "x": 0, "y": 0 }, "id": 100 },

    {
      "id": 1, "type": "timeseries", "title": "Throughput (req/s)",
      "gridPos": { "h": 8, "w": 8, "x": 0, "y": 1 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [{ "expr": "sum(rate(http_server_requests_seconds_count[1m]))", "legendFormat": "req/s" }]
    },
    {
      "id": 2, "type": "timeseries", "title": "Taxa de Erro 5xx (%)",
      "gridPos": { "h": 8, "w": 8, "x": 8, "y": 1 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": { "defaults": { "unit": "percent", "thresholds": { "steps": [
        { "color": "green", "value": null }, { "color": "red", "value": 5 }
      ] } }, "overrides": [] },
      "targets": [{
        "expr": "(sum(rate(http_server_requests_seconds_count{status=~\"5..\"}[1m])) / sum(rate(http_server_requests_seconds_count[1m]))) * 100",
        "legendFormat": "erro 5xx"
      }]
    },
    {
      "id": 3, "type": "timeseries", "title": "Contagem por Status",
      "gridPos": { "h": 8, "w": 8, "x": 16, "y": 1 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [{ "expr": "sum by(status) (rate(http_server_requests_seconds_count[1m]))", "legendFormat": "{{status}}" }]
    },
    {
      "id": 4, "type": "timeseries", "title": "Latência Média",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 9 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": { "defaults": { "unit": "s" }, "overrides": [] },
      "targets": [{
        "expr": "rate(http_server_requests_seconds_sum[1m]) / rate(http_server_requests_seconds_count[1m])",
        "legendFormat": "latência média"
      }]
    },
    {
      "id": 5, "type": "timeseries", "title": "Latência Máxima Observada",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 9 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": { "defaults": { "unit": "s" }, "overrides": [] },
      "targets": [{ "expr": "http_server_requests_seconds_max", "legendFormat": "{{uri}}" }]
    },

    { "type": "row", "title": "JVM", "gridPos": { "h": 1, "w": 24, "x": 0, "y": 17 }, "id": 101 },
    {
      "id": 10, "type": "timeseries", "title": "Heap Utilizado",
      "gridPos": { "h": 8, "w": 8, "x": 0, "y": 18 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": { "defaults": { "unit": "bytes" }, "overrides": [] },
      "targets": [{ "expr": "jvm_memory_used_bytes{area=\"heap\"}", "legendFormat": "{{id}}" }]
    },
    {
      "id": 11, "type": "timeseries", "title": "Threads Ativas",
      "gridPos": { "h": 8, "w": 8, "x": 8, "y": 18 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [{ "expr": "jvm_threads_live_threads", "legendFormat": "threads" }]
    },
    {
      "id": 12, "type": "timeseries", "title": "Pausas de GC",
      "gridPos": { "h": 8, "w": 8, "x": 16, "y": 18 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": { "defaults": { "unit": "s" }, "overrides": [] },
      "targets": [{ "expr": "rate(jvm_gc_pause_seconds_sum[5m])", "legendFormat": "{{action}}" }]
    },

    { "type": "row", "title": "Logs (Loki)", "gridPos": { "h": 1, "w": 24, "x": 0, "y": 26 }, "id": 102 },
    {
      "id": 20, "type": "logs", "title": "Logs staging_quarkus (correlação com picos)",
      "gridPos": { "h": 10, "w": 24, "x": 0, "y": 27 },
      "datasource": { "type": "loki", "uid": "loki" },
      "options": { "showTime": true, "wrapLogMessage": true },
      "targets": [{ "expr": "{container=\"staging_quarkus\"}" }]
    }
  ]
}